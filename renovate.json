{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>steled/renovate-config"
  ],
  "commitMessageAction": "update",
  "customManagers": [
    {
      "description": "Track SortableJS version in static/sortable.version",
      "customType": "regex",
      "fileMatch": ["^static/sortable\\.version$"],
      "matchStrings": ["^(?<currentValue>[\\d\\.]+)"],
      "depNameTemplate": "sortablejs",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "description": "Group Go base image updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["golang", "alpine"],
      "groupName": "Go/Alpine base images",
      "automerge": false,
      "commitMessagePrefix": "chore(deps):",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Group all Go dependency updates",
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "automerge": false,
      "commitMessagePrefix": "chore(deps):",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": false,
      "commitMessagePrefix": "chore(ci):",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ci"
    },
    {
      "description": "Ignore self-hosted registry images",
      "matchDatasources": ["docker"],
      "enabled": false,
      "matchPackageNames": [
        "/^ghcr\\.io\\/steled//"
      ]
    },
    {
      "description": "SortableJS bundled file updates",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["sortablejs"],
      "groupName": "SortableJS",
      "automerge": false,
      "commitMessagePrefix": "chore(deps):",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    }
  ],
  "gomod": {
    "enabled": true
  },
  "dockerfile": {
    "enabled": true,
    "managerFilePatterns": ["/docker/Dockerfile/"]
  },
  "github-actions": {
    "enabled": true
  }
}
